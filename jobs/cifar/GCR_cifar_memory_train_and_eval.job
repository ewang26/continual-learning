#!/bin/bash
#SBATCH -n 1
#SBATCH -N 1
#SBATCH -p gpu
#SBATCH -t 1-00:00
#SBATCH --mem=100GB
#SBATCH --gres=gpu:1
#SBATCH --job-name=continual_learning
#SBATCH -o logs/train_eval_%j.out
#SBATCH -e logs/train_eval_%j.err

export PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:128

module load cuda/12.2.0-fasrc01
module load Mambaforge/22.11.1-fasrc01
module load python/3.10.9-fasrc01

# Define paths
MAIN_PATH="/n/home12/thb489/new_continual_learning/continual-learning"
VENV_PATH="/n/home12/thb489/new_continual_learning/continual-learning/myenv"

# Set working directory explicitly
cd ${MAIN_PATH}

# Activate the virtual environment
source "${VENV_PATH}/bin/activate"

# Run the scripts and redirect output to log files
# python "${MAIN_PATH}/main_batch.py" --config "${MAIN_PATH}/configs/test/config_cifar10_grad_eval.yaml"
python "${MAIN_PATH}/main_batch.py" --config "${MAIN_PATH}/configs/GCR/config_cifar10_train.yaml"
deactivate
